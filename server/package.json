    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lightroom",
    "lightroom-classic",
    "photography",
    "claude",
    "codex",
    "chatgpt"
