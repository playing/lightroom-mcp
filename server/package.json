{
  "name": "@mskalski/lightroom-mcp",
  "version": "0.2.0",
  "description": "MCP server bridging Claude/Codex/ChatGPT to Adobe Lightroom Classic via a Lua plugin.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lightroom-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
